{
  "name": "anime-extractor",
  "version": "0.3.0",
  "description": "视频聚合源解析工具",
  "main": "./out/main/index.js",
  "author": "蒟蒻",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:portable": "electron-vite build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.anime-extractor.app",
    "productName": "Anime Extractor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "AnimeExtractor-${version}-portable.exe"
    }
  },
  "dependencies": {
    "ant-design-vue": "^4.2.0",
    "cheerio": "^1.2.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.2.0"
  }
}
